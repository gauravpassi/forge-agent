{
  "name": "forge-agent",
  "version": "1.0.0",
  "description": "Forge — Multi-agent development platform",
  "main": "dist/electron/main.js",
  "scripts": {
    "start": "npx ts-node src/index.ts",
    "build": "npx tsc",
    "electron": "npm run build && electron .",
    "electron:dev": "npm run build && electron . --dev",
    "dist": "npm run build && electron-builder --mac --dir",
    "dist:dmg": "npm run build && electron-builder --mac dmg",
    "pack": "npm run build && electron-builder --dir"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "chalk": "^5.3.0",
    "ora": "^8.0.1",
    "glob": "^11.0.0",
    "dotenv": "^16.0.0"
  },
  "devDependencies": {
    "typescript": "^5.0.0",
    "@types/node": "^20.0.0",
    "@types/electron": "^1.6.10",
    "ts-node": "^10.9.0",
    "electron": "^29.0.0",
    "electron-builder": "^24.0.0"
  },
  "build": {
    "appId": "com.upcoretech.forge",
    "productName": "Forge",
    "copyright": "Copyright © 2025 UpCore Technologies",
    "mac": {
      "category": "public.app-category.developer-tools",
      "icon": "assets/icon.icns",
      "target": [
        { "target": "dmg", "arch": ["arm64", "x64"] }
      ]
    },
    "dmg": {
      "title": "Forge Agent",
      "background": "assets/dmg-background.png",
      "window": { "width": 540, "height": 380 }
    },
    "files": [
      "dist/**/*",
      "!dist/mac-arm64/**",
      "!dist/mac/**",
      "!dist/*.dmg",
      "!dist/*.blockmap",
      "!dist/builder-debug.yml",
      "!dist/latest-mac.yml",
      "electron/renderer/**/*",
      "node_modules/**/*",
      "!node_modules/**/{CHANGELOG.md,README.md,readme.md,*.ts,test,tests,__tests__}"
    ],
    "extraResources": [
      { "from": "knowledge", "to": "knowledge" },
      { "from": ".env", "to": ".env" }
    ]
  }
}
